# Riot API key — get one at https://developer.riotgames.com
# Dev keys expire every 24h; request a production key for persistent use.
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Default player used when a tool is called without an explicit riotId.
# Quote it — the '#' would otherwise be parsed as a comment.
DEFAULT_RIOT_ID="GameName#TAG"
# Default regional routing cluster: europe | americas | asia | sea
DEFAULT_REGION=europe
# Optional: override the on-disk cache directory (default: <project>/.cache)
# CACHE_DIR=/path/to/cache
